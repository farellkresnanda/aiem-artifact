{
  "info": {
    "name": "AIEM Security Tests",
    "description": "Sanitized Postman collection for reproducing AIEM security evaluation requests. Raw JWTs, passwords, and client secrets are not included. Use the accompanying aiem.postman_environment.example.json as a template and fill values locally.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00. Setup & Token",
      "item": [
        {
          "name": "T1. Get User Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('token endpoint responded with 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.environment.set('user_token', json.access_token);",
                  "console.log('user_token refreshed');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded",
                "type": "text"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "password",
                  "type": "text"
                },
                {
                  "key": "client_id",
                  "value": "{{client_id_user}}",
                  "type": "text"
                },
                {
                  "key": "username",
                  "value": "{{username}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{password}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{token_endpoint}}",
              "host": [
                "{{token_endpoint}}"
              ]
            },
            "description": "Fetches a user access token and stores it in {{user_token}}."
          }
        },
        {
          "name": "T2. Get M2M Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('token endpoint responded with 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.environment.set('m2m_token', json.access_token);",
                  "console.log('m2m_token refreshed');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded",
                "type": "text"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "client_credentials",
                  "type": "text"
                },
                {
                  "key": "client_id",
                  "value": "{{client_id_m2m}}",
                  "type": "text"
                },
                {
                  "key": "client_secret",
                  "value": "{{client_secret_m2m}}",
                  "type": "text"
                },
                {
                  "key": "scope",
                  "value": "{{scope_public}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{token_endpoint}}",
              "host": [
                "{{token_endpoint}}"
              ]
            },
            "description": "Fetches an M2M access token and stores it in {{m2m_token}}."
          }
        }
      ]
    },
    {
      "name": "01. JWT Attacks",
      "item": [
        {
          "name": "J1. Algorithm None Attack",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{j1_alg_none_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/a/api/fetch-employee/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "a",
                "api",
                "fetch-employee",
                "1"
              ]
            },
            "description": "Expected result: gateway rejects malformed alg=none token."
          }
        },
        {
          "name": "J2. RS256 to HS256 Confusion",
