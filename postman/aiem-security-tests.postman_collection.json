              ],
              "path": [
                "api",
                "b",
                "secure",
                "employees",
                "1"
              ]
            },
            "description": "Expected result: Service B rejects user token on secure M2M endpoint."
          }
        },
        {
          "name": "S3a. M2M BOLA Prevention - Executive",
          "request": {
