    {
      "name": "02. Security Scenarios",
      "item": [
        {
          "name": "S1. SSRF Lateral Movement Baseline",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/a/api/internal-fetch?target=service-b:5001&emp_id=99",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "a",
                "api",
                "internal-fetch?target=service-b:5001&emp_id=99"
              ]
            },
            "description": "Expected result: baseline internal fetch reaches Service B internal endpoint."
          }
        },
        {
          "name": "S2. Defense-in-Depth: User Token to Service B",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
