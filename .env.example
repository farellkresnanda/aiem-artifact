# Copy this file to .env before running the artifact.
# These values are safe local reproduction placeholders. Do not use them in production.

# Keycloak admin account for local lab initialization
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-admin-password

# Kong database password for local PostgreSQL container
KONG_PG_PASSWORD=change-me-kong-db-password

# Service A confidential client secret from Keycloak
SERVICE_A_CLIENT_SECRET=change-me-service-a-client-secret

# Kong and Keycloak URLs used by scripts/setup-kong.sh
KONG_ADMIN_URL=http://localhost:8001
KEYCLOAK_ISSUER=http://localhost:8080/realms/zero-trust
KEYCLOAK_JWKS_URL=http://localhost:8080/realms/zero-trust/protocol/openid-connect/certs

# Disabled by default. Enable only when reproducing S7 credential theft simulation.
ENABLE_SIMULATED_SECRET_LEAK=false

# k6 test credentials for the local Keycloak test user
KONG_PROXY_URL=http://localhost:8000
KEYCLOAK_TOKEN_URL=http://localhost:8080/realms/zero-trust/protocol/openid-connect/token
K6_TEST_USERNAME=testuser
K6_TEST_PASSWORD=change-me-test-user-password
